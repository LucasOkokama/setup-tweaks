{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "server": {
    "port": 2000,
    "hostname": "127.0.0.1",
    "mdns": false,
    "mdnsDomain": "opencode.local",
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "ask",
    "question": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
  },
  "default_agent": "plan",
  "share": "disabled",
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000,
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".next/**",
      ".turbo/**",
      "coverage/**",
      ".cache/**",
      ".venv/**",
      "__pycache__/**",
    ],
  },
}
